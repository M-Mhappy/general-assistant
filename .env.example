# ============================================================
# 个人通用助手 — 环境变量模板
# 复制此文件为 .env 并填入真实 API 密钥
# .env 已在 .gitignore 中，不会被提交到 Git
# ============================================================

# LLM API — 支持任意 OpenAI-compatible 接口
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=deepseek-v4-pro

# Tavily Search API — 注册获取 https://tavily.com
TAVILY_API_KEY=tvly-dev-your-key-here
